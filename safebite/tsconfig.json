// TypeScript configuration - tells TypeScript how to compile the code
// Sets up React Native specific settings and includes all source files
{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "jsx": "react",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": false,
    "types": ["react", "react-native"],
    "baseUrl": "."
  },
  "include": ["App.tsx", "src/**/*"],
  "typeRoots": ["./node_modules/@types", "./src/types"]
}
